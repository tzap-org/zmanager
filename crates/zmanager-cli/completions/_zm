#compdef zm

local -a commands help_topics global_options create_options extract_options list_options test_options plan_options
local -a auth_options identity_options cert_options sign_options verify_options contact_options share_options

commands=(
  'create:Create an archive'
  'extract:Extract an archive'
  'list:List archive contents'
  'test:Test archive readability'
  'plan:Show planned archive entries'
  'formats:Show supported formats'
  'auth:Hosted TZAP auth handoff helpers'
  'me:Show the local TZAP session summary'
  'cert:Manage local TZAP certificate inventory'
  'device:Retire local TZAP device material'
  'sign:Sign a TZAP document JSON payload'
  'verify:Verify a TZAP document envelope'
  'contact:Manage TZAP contact cards'
  'share:Create a TZAP archive for contacts'
  'doctor:Verify the archive engine'
  'completions:Print shell completion scripts'
  'help:Show help for a command'
)

help_topics=(
  'create:Create an archive'
  'extract:Extract an archive'
  'list:List archive contents'
  'test:Test archive readability'
  'plan:Show planned archive entries'
  'formats:Show supported formats'
  'auth:Hosted TZAP auth handoff helpers'
  'me:Show the local TZAP session summary'
  'cert:Manage local TZAP certificate inventory'
  'device:Retire local TZAP device material'
  'sign:Sign a TZAP document JSON payload'
  'verify:Verify a TZAP document envelope'
  'contact:Manage TZAP contact cards'
  'share:Create a TZAP archive for contacts'
  'doctor:Verify the archive engine'
  'completions:Print shell completion scripts'
)

global_options=(
