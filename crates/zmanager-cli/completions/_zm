plan_options=(
  '(-h --help)'{-h,--help}'[Show help]'
  '--format[Plan for a specific archive format]:format:(zip tar.zst tzap aar 7z)'
  '(-C --directory)'{-C,--directory}'[Use directory as input base]:directory:_directories'
  '-@[Read input paths from stdin]'
  '--files-from[Read input paths from a file]:file:_files'
  '--null[Read NUL-delimited path lists]'
  '--clean[Apply clean source exclusions]'
  '--no-ignore[Ignore .gitignore/default exclusions]'
  '(-i --include)'{-i,--include}'[Include archive paths matching glob]:glob'
  '--exclude[Exclude archive paths matching glob]:glob'
  '--exclude-from[Read exclude globs from file]:file:_files'
  '--json[Emit machine-readable JSON]'
)

identity_options=(
  '(-h --help)'{-h,--help}'[Show help]'
  '--state-dir[Store local identity state in a directory]:directory:_directories'
  '--account-key[Select local account inventory]:key'
  '--json[Emit machine-readable JSON]'
)

auth_options=(
  $identity_options
  '--print-url[Print the hosted login URL]'
  '--environment[Select hosted endpoints]:environment:(local dev prod)'
  '--auth-base-url[Override hosted Auth base URL]:url'
  '--account-base-url[Override hosted Account base URL]:url'
  '--client-id[Hosted Auth client id]:id'
  '--redirect-uri[Registered callback URI]:uri'
  '--provider[Hosted provider id]:id'
  '--org-id[Organization id]:id'
  '--state[Auth callback state]:state'
  '--callback-url[Full callback URL]:url'
  '--handoff-code[One-time handoff code]:code'
  '--relay-body[Relay JSON file]:file:_files'
)

cert_options=(
  $identity_options
  '--certificate-id[Certificate id]:id'
  '--service-base-url[Hosted TZAP sign API URL]:url'
  '--trusted-root-cert[Trusted staging root certificate]:certificate:_files'
  '--org-id[Organization id]:id'
  '--requested-validity-seconds[Requested certificate lifetime]:seconds'
)

sign_options=(
  $identity_options
  '--certificate-id[Local enrolled certificate id]:id'
  '--output[Destination envelope JSON file]:file:_files'
  '--claimed-signing-time[Claimed signing time]:time'
)

verify_options=(
  '(-h --help)'{-h,--help}'[Show help]'
  '--custom-trust-root[Trust a custom root fingerprint]:fingerprint'
  '--custom-trust-root-cert[Trust a custom root certificate]:certificate:_files'
  '--status-response[Apply a status JSON response]:file:_files'
  '--time[Verification time]:unix seconds'
