  '--custom-trust-root[Trust a custom root fingerprint]:fingerprint'
  '--custom-trust-root-cert[Trust a custom root certificate]:certificate:_files'
)

share_options=(
  $identity_options
  '--contact[Accepted contact id]:id'
  '--force[Replace an existing output archive]'
)

_zm_command() {
  local context state line
  _arguments -C $global_options '1:command:->command' '*::argument:->argument'

  case $state in
    command)
      _describe -t commands 'zm command' commands
      ;;
    argument)
      case $words[1] in
        create) _arguments $create_options '*:path:_files' ;;
        extract) _arguments $extract_options '*:archive:_files' ;;
        list) _arguments $list_options '*:archive:_files' ;;
        test) _arguments $test_options '*:archive:_files' ;;
        plan) _arguments $plan_options '*:path:_files' ;;
        auth) _arguments $auth_options '1:auth command:(login callback status forget account)' '*:argument:_files' ;;
        me) _arguments $identity_options ;;
        cert) _arguments $cert_options '1:certificate command:(list enroll renew revoke)' ;;
        device) _arguments $identity_options '1:device command:(retire)' ;;
        sign) _arguments $sign_options '1:input JSON:_files' ;;
        verify) _arguments $verify_options '1:envelope JSON:_files' ;;
        contact) _arguments $contact_options '1:contact command:(export import list remove)' '*:argument:_files' ;;
        share) _arguments $share_options '1:archive:_files' '*:path:_files' ;;
        formats|doctor) _arguments '(-h --help)'{-h,--help}'[Show help]' '--json[Emit JSON]' ;;
        completions) _arguments '(-h --help)'{-h,--help}'[Show help]' '1:shell:(bash zsh fish powershell)' ;;
        help) _describe -t commands 'zm command' help_topics ;;
      esac
      ;;
  esac
}

_zm_command "$@"
