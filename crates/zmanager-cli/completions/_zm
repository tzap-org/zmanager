  '--exclude[Exclude archive paths matching glob]:glob'
  '--password-stdin[Read one password line from stdin]'
  '--recipient-key[Open TZAP RecipientWrap archives with a private key]:key:_files'
  '--public-no-key[Verify TZAP X.509 RootAuth without the archive key]'
  '--trusted-ca-cert[Trusted CA certificate for TZAP X.509 RootAuth]:certificate:_files'
  '--trusted-system-roots[Use system trust roots for TZAP X.509 RootAuth]'
